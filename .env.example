# GitLab
GITLAB_URL=https://gitlab.internal
GITLAB_PAT=glpat-xxxxx
GITLAB_PROJECT_ID=42
GITLAB_PROJECT_PATH=group/subgroup/project-name
GIT_USER_NAME=review-bot
GIT_USER_EMAIL=review-bot@company.com
WEBHOOK_SECRET=your-webhook-secret

# Service
PORT=3000
MAX_CONTAINERS=20
CONTAINER_TIMEOUT_HOURS=4

# Container
APP_PORT=7702
PREVIEW_PORT_BASE=9000
TTYD_PORT_BASE=7000
REVIEW_IMAGE=review-env:latest
CONTAINER_CPU_LIMIT=2
CONTAINER_MEMORY_LIMIT=4g

# Claude Code
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=
